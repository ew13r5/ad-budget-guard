# Database
POSTGRES_USER=adbudget
POSTGRES_PASSWORD=changeme
POSTGRES_DB=adbudget
DATABASE_URL=postgresql://adbudget:changeme@postgres:5432/adbudget

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Meta API
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v19.0

# Auth
SECRET_KEY=change-me-to-random-string
ENCRYPTION_KEY=generate-with-fernet-generate-key

# Mode (default for new accounts: simulation | meta_sandbox | production)
AD_DATA_MODE=simulation

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Telegram (for alerts, used by split 05)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
