# Ad Budget Guard — Production Environment Configuration
# Copy this file to .env and fill in real values

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://adbudget:CHANGE_ME@db-host:5432/adbudget
POSTGRES_HOST=db-host

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis-host:6379/0
CELERY_BROKER_URL=redis://redis-host:6379/1
CELERY_RESULT_BACKEND=redis://redis-host:6379/2

# ── Meta API (from Meta Developer Dashboard) ─────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_API_VERSION=v19.0
FACEBOOK_REDIRECT_URI=https://yourdomain.com/auth/callback

# ── Security ─────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_FERNET

# ── Operating Mode ───────────────────────────────────────
AD_DATA_MODE=production

# ── SMTP Email Alerts ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=alerts@yourdomain.com
SMTP_USE_SSL=false

# ── Telegram Alerts ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token

# ── Sentry Error Tracking (optional) ────────────────────
SENTRY_DSN=

# ── CORS (JSON array of allowed origins) ─────────────────
CORS_ORIGINS=["https://yourdomain.com"]
